# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
# Backward-compatibility alias (optional if DISCORD_BOT_TOKEN is set)
# DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_server_id_here
DISCORD_CATEGORY_NAME=OpenCode Projects
DISCORD_APPLICATION_ID=your_discord_application_id_here
DISCORD_PUBLIC_KEY=your_discord_public_key_here
# Optional: comma-separated role IDs to trigger mention handlers
# DISCORD_MENTION_ROLE_IDS=1234567890,0987654321

# Optional: if set, gateway events are forwarded to this webhook URL
# DISCORD_WEBHOOK_URL=https://your-domain.com/api/webhooks/discord
DISCORD_GATEWAY_DURATION_MS=600000
DISCORD_GATEWAY_RESTART_DELAY_MS=2000

# Express Server Configuration
PORT=3000
WEBHOOK_SECRET=your_webhook_secret_here

# OpenCode Configuration
OPENCODE_PERMISSION_MODE=allow
OPENCODE_RUN_TIMEOUT_MS=300000
OPENCODE_SERVER_START_TIMEOUT_MS=30000
OPENCODE_RUN_RETRY_COUNT=1
OPENCODE_MAX_PROMPT_LENGTH=8000
OPENCODE_MAX_OUTPUT_LENGTH=1800

# Projects file path (relative to project root)
PROJECTS_FILE=./projects.json

# SQLite database path (relative to project root)
DB_PATH=./data/maximus.db
