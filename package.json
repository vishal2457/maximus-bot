{
  "name": "discord-opencode-bridge",
  "version": "1.0.0",
  "description": "Discord bot that routes messages to OpenCode in project workspaces",
  "scripts": {
    "build": "node build.js",
    "clean": "rm -rf dist",
    "dev": "nodemon --exec \"node -r esbuild-register ./src/index.ts\" -e .ts",
    "start": "node -r esbuild-register ./src/index.ts",
    "format": "prettier --write .",
    "lint": "prettier --check ."
  },
  "dependencies": {
    "@chat-adapter/discord": "^4.19.0",
    "@chat-adapter/state-memory": "^4.19.0",
    "@opencode-ai/sdk": "^1.2.24",
    "axios": "^1.6.2",
    "chat": "^4.19.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.2.3",
    "esbuild": "^0.20.1",
    "esbuild-register": "^3.5.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.6.2",
    "typescript": "^5.3.3",
    "vitest": "^3.0.9"
  }
}