{
  "name": "maximus",
  "version": "1.0.0",
  "description": "Discord bot that routes messages to OpenCode in project workspaces",
  "scripts": {
    "build": "node build.js",
    "clean": "rm -rf dist",
    "dev": "nodemon --exec \"node -r esbuild-register ./src/index.ts\" -e .ts",
    "start": "node -r esbuild-register ./src/index.ts",
    "pm2:start": "pnpm run build && pm2 start ecosystem.config.cjs --env production",
    "pm2:restart": "pnpm run build && pm2 reload ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 delete maximus",
    "pm2:ls": "pm2 ls",
    "format": "prettier --write .",
    "lint": "prettier --check ."
  },
  "dependencies": {
    "@chat-adapter/discord": "^4.20.1",
    "@chat-adapter/state-memory": "^4.20.1",
    "@openai/codex-sdk": "^0.114.0",
    "@opencode-ai/sdk": "^1.2.24",
    "axios": "^1.6.2",
    "better-sqlite3": "^12.6.2",
    "chat": "^4.20.1",
    "discord.js": "^14.19.3",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "keytar": "^7.9.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^25.2.3",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.20.2",
    "esbuild-register": "^3.5.0",
    "nodemon": "^3.1.0",
    "pm2": "^6.0.14",
    "prettier": "^3.6.2",
    "typescript": "^5.3.3",
    "vitest": "^3.0.9"
  }
}
